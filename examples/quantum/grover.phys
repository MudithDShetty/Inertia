// Grover search — 2-qubit demonstration

qreg q[2]

fn grover_diffuser() -> Circuit {
    H(0)
    H(1)
    X(0)
    X(1)
    H(1)
    CNOT(0, 1)
    H(1)
    X(0)
    X(1)
    H(0)
    H(1)
    return ansatz(q, 0.0)
}

fn grover_circuit() -> Circuit {
    H(0)
    H(1)
    X(0)
    CNOT(0, 1)
    return grover_diffuser()
}

fn main() -> Int {
    let circ = grover_circuit()
    let result = sample(circ, 1024)
    return 0
}
